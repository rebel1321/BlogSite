# Backend Server Configuration

# MongoDB connection string
MONGO_URI=mongodb+srv://admin:PASSWORD@cluster.mongodb.net

# Server port
PORT=8080

# Frontend URLs for CORS (comma-separated for multiple environments)

# LOCAL DEVELOPMENT - Allow only local frontend
# ALLOWED_ORIGINS=http://localhost:5173

# PRODUCTION - Allow production frontend
# ALLOWED_ORIGINS=https://blog-site-mve9bi7th-satyam-tripathis-projects-ad4a3527.vercel.app

# BOTH LOCAL + PRODUCTION - Use this for flexibility
ALLOWED_ORIGINS=http://localhost:5173,https://blog-site-mve9bi7th-satyam-tripathis-projects-ad4a3527.vercel.app

# Cloudinary Configuration (for image uploads)
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_SECRET_KEY=your_secret_key
